{
  "name": "nextma",
  "version": "2.1.0",
  "description": "Next.js codebase knowledge graph — scan, query, visualize",
  "keywords": [
    "nextjs",
    "mcp",
    "model-context-protocol",
    "ai",
    "codebase",
    "knowledge-graph",
    "claude",
    "cursor",
    "figma",
    "codegen",
    "static-analysis",
    "developer-tools"
  ],
  "author": {
    "email": "seb.madcat@gmail.com",
    "name": "mad cat"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist/"
  ],
  "main": "dist/cli.js",
  "bin": {
    "nextma": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "chmod +x dist/cli.js",
    "dev": "ts-node src/cli.ts",
